<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/viewEstadoColor"
            android:layout_width="10dp"
            android:layout_height="10dp"
            app:cardBackgroundColor="#22C55E"
            app:cardCornerRadius="5dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/tvLineaFalla"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvLineaFalla" />

        <TextView
            android:id="@+id/tvLineaFalla"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:text="Descripción de la falla"
            android:textColor="#1E293B"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/tvEstadoTexto"
            app:layout_constraintStart_toEndOf="@+id/viewEstadoColor"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvReporteTecnico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Reporte técnico de sistema"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@+id/tvLineaFalla"
            app:layout_constraintTop_toBottomOf="@+id/tvLineaFalla" />

        <TextView
            android:id="@+id/tvEstadoTexto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="ESTADO"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>